@model IEnumerable<SchoolApp.ViewModels.Users.UserListItemVM>

@{
    ViewData["Title"] = "Users Management";
}

<div class="container mt-4">

    <!-- Header -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body d-flex justify-content-between align-items-center">

            <div>
                <h2 class="fw-bold mb-1">Users Management</h2>
                <p class="text-muted mb-0">
                    Manage accounts, roles, activation, lockout, and recovery actions.
                </p>
            </div>

        </div>
    </div>

    <!-- Users Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-body">

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">
                        <tr>
                            <th>User</th>
                            <th>Roles</th>
                            <th>Status</th>
                            <th class="text-end">Manage</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var user in Model)
                        {
                            var isTeacher = user.Roles.Contains("Teacher");

                            <tr>
                                <!-- User -->
                                <td>
                                    <div class="fw-semibold">
                                        @user.Email
                                    </div>
                                    <small class="text-muted">
                                        ID: @user.Id.Substring(0, 8)...
                                    </small>
                                </td>

                                <!-- Roles -->
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(user.Roles) && user.Roles != "No Role")
                                    {
                                        foreach (var role in user.Roles.Split(","))
                                        {
                                            <span class="badge bg-light text-dark border me-1">
                                                @role.Trim()
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">
                                            No Role
                                        </span>
                                    }
                                </td>

                                <!-- Status -->
                                <td>
                                    @if (user.IsActive)
                                    {
                                        <span class="badge bg-success">
                                            Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">
                                            Inactive
                                        </span>
                                    }

                                    @if (user.IsLocked)
                                    {
                                        <span class="badge bg-danger ms-1">
                                            Locked
                                        </span>
                                    }
                                </td>

                                <!-- Manage -->
                                <td class="text-end">

                                    <div class="btn-group">

                                        <a asp-action="Details"
                                               asp-route-id="@user.Id"
                                               class="btn btn-sm btn-outline-info">
                                            Details
                                        </a>

                                        <button type="button"
                                                class="btn btn-sm btn-outline-primary dropdown-toggle dropdown-toggle-split"
                                                data-bs-toggle="dropdown">
                                            <span class="visually-hidden">Toggle Dropdown</span>
                                        </button>

                                        <ul class="dropdown-menu dropdown-menu-end">

                                            <li>
                                                <a class="dropdown-item"
                                                       asp-action="ChangeRole"
                                                       asp-route-id="@user.Id">
                                                    Change Role
                                                </a>
                                            </li>

                                            <li>
                                                <a class="dropdown-item"
                                                       asp-action="ResetPassword"
                                                       asp-route-id="@user.Id">
                                                    Reset Password
                                                </a>
                                            </li>

                                            @if (isTeacher)
                                            {
                                                <li>
                                                    <form asp-action="FixTeacherAccount"
                                                          asp-route-id="@user.Id"
                                                          method="post">

                                                        @Html.AntiForgeryToken()

                                                        <button type="submit"
                                                                class="dropdown-item">
                                                            Fix Teacher Account
                                                        </button>
                                                    </form>
                                                </li>
                                            }

                                            <li><hr class="dropdown-divider" /></li>

                                            @if (user.IsLocked)
                                            {
                                                <li>
                                                    <form asp-action="UnlockUser"
                                                          asp-route-id="@user.Id"
                                                          method="post">

                                                        @Html.AntiForgeryToken()

                                                        <button type="submit"
                                                                class="dropdown-item text-success">
                                                            Unlock Account
                                                        </button>
                                                    </form>
                                                </li>
                                            }
                                            else
                                            {
                                                <li>
                                                    <form asp-action="LockUser"
                                                          asp-route-id="@user.Id"
                                                          method="post">

                                                        @Html.AntiForgeryToken()

                                                        <button type="submit"
                                                                class="dropdown-item text-danger">
                                                            Lock Account
                                                        </button>
                                                    </form>
                                                </li>
                                            }

                                            @if (user.IsActive)
                                            {
                                                <li>
                                                    <form asp-action="DeactivateUser"
                                                          asp-route-id="@user.Id"
                                                          method="post">

                                                        @Html.AntiForgeryToken()

                                                        <button type="submit"
                                                                class="dropdown-item text-danger">
                                                            Deactivate User
                                                        </button>
                                                    </form>
                                                </li>
                                            }
                                            else
                                            {
                                                <li>
                                                    <form asp-action="ActivateUser"
                                                          asp-route-id="@user.Id"
                                                          method="post">

                                                        @Html.AntiForgeryToken()

                                                        <button type="submit"
                                                                class="dropdown-item text-success">
                                                            Activate User
                                                        </button>
                                                    </form>
                                                </li>
                                            }

                                        </ul>
                                    </div>

                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>