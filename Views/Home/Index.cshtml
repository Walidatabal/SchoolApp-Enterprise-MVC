                <div class="col-md-3">
                    <div class="p-3 border rounded-4 h-100">
                        <h6 class="fw-bold">Clean Architecture</h6>
                        <small class="text-muted">
                            Controller → Service → UnitOfWork → Repository.
                        </small>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="p-3 border rounded-4 h-100">
