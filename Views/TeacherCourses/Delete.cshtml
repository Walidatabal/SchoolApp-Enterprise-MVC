@model SchoolApp.ViewModels.TeacherCourses.TeacherCourseListItemVM

@{
    ViewData["Title"] = "Delete Teacher Course Assignment";
}

<h2>Delete Assignment</h2>

<div class="alert alert-warning">
    Are you sure you want to delete this assignment?
</div>

<dl class="row">
    <dt class="col-sm-2">Teacher</dt>
    <dd class="col-sm-10">@Model.TeacherName</dd>

    <dt class="col-sm-2">Course</dt>
    <dd class="col-sm-10">@Model.CourseName</dd>
</dl>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" name="teacherId" value="@Model.TeacherId" />
    <input type="hidden" name="courseId" value="@Model.CourseId" />

    <button type="submit" class="btn btn-danger">
        Delete
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Cancel
    </a>
</form>