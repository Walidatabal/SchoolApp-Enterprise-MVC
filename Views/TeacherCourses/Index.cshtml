@model IEnumerable<SchoolApp.ViewModels.TeacherCourses.TeacherCourseListItemVM>

@{
    ViewData["Title"] = "Teacher Courses";
}

<div class="container mt-4">

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body d-flex justify-content-between align-items-center">

            <div>
                <h2 class="fw-bold mb-1">Teacher Course Assignments</h2>
                <p class="text-muted mb-0">
                    Manage course assignments for teachers.
                </p>
            </div>

            <a asp-action="Assign"
                   class="btn btn-primary rounded-pill px-4">
                + Assign Courses
            </a>

        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">
                        <tr>
                            <th>Teacher Name</th>
                            <th>Course Name</th>
                            <th class="text-end" style="width:260px;">
                                Actions
                            </th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">
                                        @item.TeacherName
                                    </td>

                                    <td>
                                        <span class="badge bg-light text-dark border">
                                            @item.CourseName
                                        </span>
                                    </td>

                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-2">

                                            <a asp-action="Edit"
                                                   asp-route-teacherId="@item.TeacherId"
                                                   asp-route-courseId="@item.CourseId"
                                                   class="btn btn-outline-warning btn-sm rounded-pill px-3">
                                                Edit
                                            </a>

                                            <a asp-action="Delete"
                                                   asp-route-teacherId="@item.TeacherId"
                                                   asp-route-courseId="@item.CourseId"
                                                   class="btn btn-outline-danger btn-sm rounded-pill px-3">
                                                Delete
                                            </a>

                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted py-4">
                                    No teacher-course assignments found.
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>

            </div>

        </div>
    </div>

</div>