@model SchoolApp.ViewModels.Students.StudentDetailsVM

@{
    ViewData["Title"] = "Delete Student";
}

<h2 class="mb-4">Delete Student</h2>

<div class="alert alert-warning">
    Are you sure you want to delete this student?
</div>

<dl class="row">
    <dt class="col-sm-2">Student Name</dt>
    <dd class="col-sm-10">@Model.Name</dd>

    <dt class="col-sm-2">Birth Date</dt>
    <dd class="col-sm-10">@Model.BirthDate.ToShortDateString()</dd>

    <dt class="col-sm-2">Parent</dt>
    <dd class="col-sm-10">@Model.ParentName</dd>
</dl>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" name="id" value="@Model.Id" />

    <div class="mt-4 d-flex gap-2">
        <button type="submit"
                class="btn btn-outline-danger rounded-pill px-4">
            Delete
        </button>

        <a asp-action="Index"
               class="btn btn-outline-secondary rounded-pill px-4">
            Cancel
        </a>
    </div>
</form>