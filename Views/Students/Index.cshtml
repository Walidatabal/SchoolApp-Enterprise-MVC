@model IEnumerable<SchoolApp.ViewModels.Students.StudentListItemVM>

@using SchoolApp.Common.Constants

@{
    ViewData["Title"] = "Students";
}

<div class="container mt-4">

    <!-- Header Card -->
    <div class="card border-0 shadow-sm mb-4">

        <div class="card-body d-flex justify-content-between align-items-center">

            <div>
                <h2 class="fw-bold mb-1">Students</h2>

                <p class="text-muted mb-0">
                    View students and parent assignments.
                </p>
            </div>

            @if (User.IsInRole(Roles.Admin))
            {
                <a asp-action="Create"
                       class="btn btn-primary rounded-pill px-4">

                    + Add Student

                </a>
            }

        </div>

    </div>

    <!-- Table Card -->
    <div class="card border-0 shadow-sm">

        <div class="card-body">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show"
                     role="alert">

                    @TempData["Success"]

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="alert">
                    </button>

                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show"
                     role="alert">

                    @TempData["Error"]

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="alert">
                    </button>

                </div>
            }

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">

                        <tr>

                            <th>Student</th>

                            <th>Birth Date</th>

                            <th>Parent</th>

                            <th class="text-end"
                                style="width:340px;">

                                Actions

                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        @if (!Model.Any())
                        {
                            <tr>

                                <td colspan="4"
                                    class="text-center text-muted py-4">

                                    No students found.

                                </td>

                            </tr>
                        }
                        else
                        {
                            foreach (var student in Model)
                            {
                                <tr>

                                    <!-- STUDENT -->
                                    <td>

                                        <div class="fw-semibold">
                                            @student.Name
                                        </div>

                                    </td>

                                    <!-- BIRTH DATE -->
                                    <td>

                                        <span class="badge bg-light text-dark border">
                                            @student.BirthDate.ToString("yyyy-MM-dd")
                                        </span>

                                    </td>

                                    <!-- PARENT -->
                                    <td>

                                        @if (!string.IsNullOrWhiteSpace(student.ParentName))
                                        {
                                            <span class="text-dark">
                                                @student.ParentName
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                No Parent
                                            </span>
                                        }

                                    </td>

                                    <!-- ACTIONS -->
                                    <td class="text-end">

                                        <div class="d-flex justify-content-end gap-2">

                                            <!-- DETAILS -->
                                            <a asp-action="Details"
                                                   asp-route-id="@student.Id"
                                                   class="btn btn-outline-info btn-sm rounded-pill px-3">

                                                Details

                                            </a>

                                            @if (User.IsInRole(Roles.Admin))
                                            {
                                                <!-- EDIT -->
                                                <a asp-action="Edit"
                                                       asp-route-id="@student.Id"
                                                       class="btn btn-outline-warning btn-sm rounded-pill px-3">

                                                    Edit

                                                </a>

                                                <!-- DELETE BUTTON -->
                                                <button type="button"
                                                        class="btn btn-outline-danger btn-sm rounded-pill px-3"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#deleteStudentModal-@student.Id">

                                                    Delete

                                                </button>
                                            }

                                        </div>

                                        <!-- DELETE MODAL -->
                                        <div class="modal fade"
                                             id="deleteStudentModal-@student.Id"
                                             tabindex="-1"
                                             aria-labelledby="deleteStudentModalLabel-@student.Id"
                                             aria-hidden="true">

                                            <div class="modal-dialog modal-dialog-centered">

                                                <div class="modal-content border-0 shadow">

                                                    <!-- HEADER -->
                                                    <div class="modal-header bg-danger text-white">

                                                        <h5 class="modal-title"
                                                            id="deleteStudentModalLabel-@student.Id">

                                                            Delete Student

                                                        </h5>

                                                        <button type="button"
                                                                class="btn-close btn-close-white"
                                                                data-bs-dismiss="modal">
                                                        </button>

                                                    </div>

                                                    <!-- BODY -->
                                                    <div class="modal-body text-center">

                                                        <div class="mb-3">

                                                            <i class="bi bi-exclamation-triangle-fill text-danger"
                                                                   style="font-size:3rem;">
                                                            </i>

                                                        </div>

                                                        <h5 class="fw-bold text-danger mb-3">
                                                            Warning!
                                                        </h5>

                                                        <p class="mb-1">
                                                            Are you sure you want to delete this student?
                                                        </p>

                                                        <h4 class="fw-bold">
                                                            @student.Name
                                                        </h4>

                                                        <p class="text-muted mt-3">
                                                            Related enrollments will also be removed.
                                                        </p>

                                                        <p class="text-danger small mb-0">
                                                            This action cannot be undone.
                                                        </p>

                                                    </div>

                                                    <!-- FOOTER -->
                                                    <div class="modal-footer">

                                                        <button type="button"
                                                                class="btn btn-outline-secondary rounded-pill px-4"
                                                                data-bs-dismiss="modal">

                                                            Cancel

                                                        </button>

                                                        <form asp-action="Delete"
                                                              asp-route-id="@student.Id"
                                                              method="post">

                                                            @Html.AntiForgeryToken()

                                                            <button type="submit"
                                                                    class="btn btn-outline-danger rounded-pill px-4">

                                                                Confirm Delete

                                                            </button>

                                                        </form>

                                                    </div>

                                                </div>

                                            </div>

                                        </div>

                                    </td>

                                </tr>
                            }
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>