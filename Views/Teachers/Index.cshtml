@model IEnumerable<SchoolApp.ViewModels.Teachers.TeacherListItemVM>

@using SchoolApp.Common.Constants

@{
    ViewData["Title"] = "Teachers";
}

<div class="container mt-4">

    <!-- ========================= -->
    <!-- HEADER CARD -->
    <!-- ========================= -->
    <div class="card border-0 shadow-sm mb-4">

        <div class="card-body d-flex justify-content-between align-items-center">

            <div>

                <h2 class="fw-bold mb-1">
                    Teachers
                </h2>

                <p class="text-muted mb-0">
                    View teachers and their specializations.
                </p>

            </div>

            <!-- ADMIN ONLY -->
            @if (User.IsInRole(Roles.Admin))
            {
                <a asp-action="Create"
                       class="btn btn-success rounded-pill px-4">

                    + Add Teacher

                </a>
            }

        </div>

    </div>

    <!-- ========================= -->
    <!-- TABLE CARD -->
    <!-- ========================= -->
    <div class="card border-0 shadow-sm">

        <div class="card-body">
            
            <!-- SUCCESS MESSAGE -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show"
                     role="alert">

                    @TempData["Success"]

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="alert">
                    </button>

                </div>
            }

            <!-- ERROR MESSAGE -->
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show"
                     role="alert">

                    @TempData["Error"]

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="alert">
                    </button>

                </div>
            }

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0"
                       style="vertical-align:middle;">

                    <thead class="table-light">

                        <tr>

                            <th>Teacher</th>

                            <th>Specialization</th>

                            <th class="text-end"
                                style="width:320px;">

                                Actions

                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        @if (!Model.Any())
                        {
                            <tr>

                                <td colspan="3"
                                    class="text-center text-muted py-4">

                                    No teachers found.

                                </td>

                            </tr>
                        }
                        else
                        {
                            foreach (var teacher in Model)
                            {
                                <tr>

                                    <!-- TEACHER NAME -->
                                    <td>

                                        <div class="fw-semibold">
                                            @teacher.Name
                                        </div>

                                    </td>

                                    <!-- SPECIALIZATION -->
                                    <td>

                                        @if (!string.IsNullOrWhiteSpace(teacher.Specialization))
                                        {
                                            <span class="badge bg-light text-dark border">
                                                @teacher.Specialization
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">
                                                No Specialization
                                            </span>
                                        }

                                    </td>

                                    <!-- ACTIONS -->
                                    <td class="text-end">

                                        <div class="d-flex justify-content-end gap-2">

                                            <!-- DETAILS -->
                                            <a asp-action="Details"
                                                   asp-route-id="@teacher.Id"
                                                   class="btn btn-outline-info btn-sm rounded-pill px-3">

                                                Details

                                            </a>

                                            @if (User.IsInRole(Roles.Admin))
                                            {
                                                <!-- EDIT -->
                                                <a asp-action="Edit"
                                                       asp-route-id="@teacher.Id"
                                                       class="btn btn-outline-warning btn-sm rounded-pill px-3">

                                                    Edit

                                                </a>

                                                <!-- DELETE -->
                                                <a asp-action="Delete"
                                                       asp-route-id="@teacher.Id"
                                                       class="btn btn-outline-danger btn-sm rounded-pill px-3">

                                                    Delete

                                                </a>
                                            }

                                        </div>

                                    </td>

                                </tr>
                            }
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

