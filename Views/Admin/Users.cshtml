@model List<SchoolApp.ViewModels.Admin.UserRoleVM>

@{
    ViewData["Title"] = "Manage Users & Roles";
}

<div class="container py-4">

    <!-- PAGE HEADER -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Manage Users & Roles</h2>
            <p class="text-muted mb-0">Create users, assign admin access, and manage account actions.</p>
        </div>

        <div class="mt-3 mt-md-0">
            <a asp-action="CreateUser" class="btn btn-primary rounded-3 px-4">
                + Create User
            </a>
        </div>
    </div>

    <!-- SUCCESS / ERROR MESSAGES -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- USERS CARD -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">

            <div class="p-3 border-bottom">
                <h5 class="fw-semibold mb-1">Registered Users</h5>
                <small class="text-muted">Manage user roles and account actions from one place.</small>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">User</th>
                            <th>User Role</th>
                            <th>Admin Role</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <!-- USER EMAIL -->
                                <td class="ps-4">
                                    <div class="fw-semibold">@item.Email</div>
                                    <small class="text-muted">User account</small>
                                </td>

                                <!-- USER ROLE -->
                                <td>
                                    @if (item.IsUser)
                                    {
                                        <span class="badge rounded-pill bg-secondary-subtle text-dark border px-3 py-2">
                                            User
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No User role</span>
                                    }
                                </td>

                                <!-- ADMIN ROLE -->
                                <td>
                                    @if (item.IsAdmin)
                                    {
                                        <span class="badge rounded-pill bg-danger-subtle text-danger border border-danger-subtle px-3 py-2">
                                            Admin
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Not Admin</span>
                                    }
                                </td>

                                <!-- ACTIONS -->
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end flex-wrap gap-2">

                                        @if (!item.IsAdmin)
                                        {
                                            <form asp-action="MakeAdmin" method="post" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@item.UserId" />
                                                <button type="submit" class="btn btn-sm btn-outline-success rounded-3">
                                                    Make Admin
                                                </button>
                                            </form>
                                        }
                                        else if (item.Email != User.Identity!.Name)
                                        {
                                            <form asp-action="RemoveAdmin" method="post" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@item.UserId" />
                                                <button type="submit"
                                                        class="btn btn-sm btn-outline-warning rounded-3"
                                                        onclick="return confirm('Remove Admin role from this user?')">
                                                    Remove Admin
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-light text-dark border px-3 py-2">
                                                Current Admin
                                            </span>
                                        }

                                        <a asp-action="ResetPassword"
                                               asp-route-userId="@item.UserId"
                                               class="btn btn-sm btn-outline-primary rounded-3">
                                            Reset Password
                                        </a>

                                        @if (item.Email != User.Identity!.Name)
                                        {
                                            <form asp-action="DeleteUser" method="post" class="m-0">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@item.UserId" />
                                                <button type="submit"
                                                        class="btn btn-sm btn-outline-danger rounded-3"
                                                        onclick="return confirm('Are you sure you want to delete this user?')">
                                                    Delete
                                                </button>
                                            </form>
                                        }

                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>