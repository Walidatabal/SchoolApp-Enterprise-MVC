@model SchoolApp.ViewModels.Admin.ChangeRoleVM

<h2>Confirm Role Change</h2>

<div class="alert alert-warning">
    Are you sure you want to <strong>@Model.Action</strong> the following user?
</div>

<dl class="row">
    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>
</dl>

@* ✅ The form action dynamically targets MakeAdmin or RemoveAdmin
   depending on which action brought us here *@
<form method="post">
    <input type="hidden" name="userId" value="@Model.UserId" />
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-warning">Yes, Confirm</button>
    <a asp-action="Users" class="btn btn-secondary">Cancel</a>
</form>