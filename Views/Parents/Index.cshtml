@model IEnumerable<SchoolApp.ViewModels.Parents.ParentListItemVM>

@{
    ViewData["Title"] = "Parents";
}

<div class="container-fluid px-4">

    <div class="card shadow-sm border-0 mt-4">

        <div class="card-body">

            <!-- PAGE HEADER -->
            <div class="d-flex justify-content-between align-items-center mb-4">

                <div>
                    <h2 class="fw-bold mb-1">
                        Parents
                    </h2>

                    <p class="text-muted mb-0">
                        Manage parents and guardians.
                    </p>
                </div>

                <a asp-action="Create"
                       class="btn btn-primary rounded-pill px-4">

                    + Add Parent

                </a>

            </div>

            <!-- SUCCESS MESSAGE -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show"
                     role="alert">

                    @TempData["Success"]

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="alert">
                    </button>

                </div>
            }

            <!-- ERROR MESSAGE -->
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show"
                     role="alert">

                    @TempData["Error"]

                    <button type="button"
                            class="btn-close"
                            data-bs-dismiss="alert">
                    </button>

                </div>
            }

            <!-- TABLE -->
            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">

                        <tr>
                            <th>Name</th>
                            <th>Phone</th>
                            <th>Email</th>
                            <th class="text-center">Students</th>
                            <th class="text-end" style="width:320px;">
                                Actions
                            </th>
                        </tr>

                    </thead>

                    <tbody>

                        @if (!Model.Any())
                        {
                            <tr>

                                <td colspan="5"
                                    class="text-center text-muted py-4">

                                    No parents found.

                                </td>

                            </tr>
                        }
                        else
                        {
                            foreach (var parent in Model)
                            {
                                <tr>

                                    <!-- NAME -->
                                    <td class="fw-semibold">
                                        @parent.FullName
                                    </td>

                                    <!-- PHONE -->
                                    <td>
                                        @parent.PhoneNumber
                                    </td>

                                    <!-- EMAIL -->
                                    <td>
                                        @parent.Email
                                    </td>

                                    <!-- STUDENTS COUNT -->
                                    <td class="text-center">

                                        <span class="badge bg-info">
                                            @parent.StudentsCount
                                        </span>

                                    </td>

                                    <!-- ACTIONS -->
                                    <td class="text-end">

                                        <div class="d-flex justify-content-end gap-2">

                                            <!-- DETAILS -->
                                            <a asp-action="Details"
                                                   asp-route-id="@parent.Id"
                                                   class="btn btn-outline-info btn-sm rounded-pill px-3">

                                                Details

                                            </a>

                                            <!-- EDIT -->
                                            <a asp-action="Edit"
                                                   asp-route-id="@parent.Id"
                                                   class="btn btn-outline-warning btn-sm rounded-pill px-3">

                                                Edit

                                            </a>

                                            <!-- DELETE -->
                                            <button type="button"
                                                    class="btn btn-outline-danger btn-sm rounded-pill px-3"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#deleteModal-@parent.Id">

                                                Delete

                                            </button>

                                        </div>

                                        <!-- DELETE MODAL -->
                                        <div class="modal fade"
                                             id="deleteModal-@parent.Id"
                                             tabindex="-1"
                                             aria-labelledby="deleteModalLabel-@parent.Id"
                                             aria-hidden="true">

                                            <div class="modal-dialog modal-dialog-centered">

                                                <div class="modal-content border-0 shadow">

                                                    <!-- MODAL HEADER -->
                                                    <div class="modal-header bg-danger text-white">

                                                        <h5 class="modal-title"
                                                            id="deleteModalLabel-@parent.Id">

                                                            Delete Parent

                                                        </h5>

                                                        <button type="button"
                                                                class="btn-close btn-close-white"
                                                                data-bs-dismiss="modal">
                                                        </button>

                                                    </div>

                                                    <!-- MODAL BODY -->
                                                    <div class="modal-body">

                                                        <div class="text-center">

                                                            <div class="mb-3">

                                                                <i class="bi bi-exclamation-triangle-fill text-danger"
                                                                       style="font-size:3rem;">
                                                                </i>

                                                            </div>

                                                            <h5 class="fw-bold text-danger mb-3">
                                                                Warning!
                                                            </h5>

                                                            <p class="mb-1">
                                                                Are you sure you want to delete:
                                                            </p>

                                                            <h4 class="fw-bold">
                                                                @parent.FullName
                                                            </h4>

                                                            <p class="text-muted mt-3">
                                                                Related students will be unlinked from this parent.
                                                            </p>

                                                            <p class="text-danger small mb-0">
                                                                This action cannot be undone.
                                                            </p>

                                                        </div>

                                                    </div>

                                                    <!-- MODAL FOOTER -->
                                                    <div class="modal-footer">

                                                        <button type="button"
                                                                class="btn btn-outline-secondary rounded-pill px-4"
                                                                data-bs-dismiss="modal">

                                                            Cancel

                                                        </button>

                                                        <form asp-action="Delete"
                                                              asp-route-id="@parent.Id"
                                                              method="post">

                                                            @Html.AntiForgeryToken()

                                                            <button type="submit"
                                                                    class="btn btn-outline-danger rounded-pill px-4">

                                                                Confirm Delete

                                                            </button>

                                                        </form>

                                                    </div>

                                                </div>

                                            </div>

                                        </div>

                                    </td>

                                </tr>
                            }
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>