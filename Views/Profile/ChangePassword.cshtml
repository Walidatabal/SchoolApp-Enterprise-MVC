@model SchoolApp.ViewModels.Profile.ChangePasswordVM

@{
    ViewData["Title"] = "Change Password";
}

<!-- ========================= -->
<!-- PAGE HEADER -->
<!-- ========================= -->
<div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h2 class="fw-bold mb-1">
            Change Password
        </h2>

        <p class="text-muted mb-0">
            Update your account password securely.
        </p>
    </div>

</div>

<!-- ========================= -->
<!-- CHANGE PASSWORD CARD -->
<!-- ========================= -->
<div class="card border-0 shadow-sm rounded-4">

    <div class="card-body p-4">

        <!-- Validation Summary -->
        <div asp-validation-summary="ModelOnly"
             class="alert alert-danger">
        </div>

        <!-- ========================= -->
        <!-- CHANGE PASSWORD FORM -->
        <!-- ========================= -->
        <form asp-action="ChangePassword"
              method="post">

            @Html.AntiForgeryToken()

            <div class="row g-3">

                <!-- ========================= -->
                <!-- CURRENT PASSWORD -->
                <!-- ========================= -->
                <div class="col-12">

                    <label asp-for="CurrentPassword"
                           class="form-label fw-semibold">
                        Current Password
                    </label>

                    <input asp-for="CurrentPassword"
                           type="password"
                           class="form-control form-control-lg"
                           placeholder="Enter current password" />

                    <span asp-validation-for="CurrentPassword"
                          class="text-danger small">
                    </span>

                </div>

                <!-- ========================= -->
                <!-- NEW PASSWORD -->
                <!-- ========================= -->
                <div class="col-md-6">

                    <label asp-for="NewPassword"
                           class="form-label fw-semibold">
                        New Password
                    </label>

                    <input asp-for="NewPassword"
                           type="password"
                           class="form-control form-control-lg"
                           placeholder="Enter new password" />

                    <span asp-validation-for="NewPassword"
                          class="text-danger small">
                    </span>

                </div>

                <!-- ========================= -->
                <!-- CONFIRM PASSWORD -->
                <!-- ========================= -->
                <div class="col-md-6">

                    <label asp-for="ConfirmPassword"
                           class="form-label fw-semibold">
                        Confirm Password
                    </label>

                    <input asp-for="ConfirmPassword"
                           type="password"
                           class="form-control form-control-lg"
                           placeholder="Confirm new password" />

                    <span asp-validation-for="ConfirmPassword"
                          class="text-danger small">
                    </span>

                </div>

            </div>

            <!-- ========================= -->
            <!-- ACTION BUTTONS -->
            <!-- ========================= -->
            <div class="mt-4 d-flex gap-2">

                <!-- Submit -->
                <button type="submit"
                        class="btn btn-primary px-4">

                    Change Password

                </button>

                <!-- Back -->
                <a asp-action="Index"
                       class="btn btn-outline-secondary">

                    Back to Profile

                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}