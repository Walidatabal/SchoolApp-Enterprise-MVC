@model SchoolApp.ViewModels.Dashboard.DashboardVM

@{
    ViewData["Title"] = "Dashboard";
}

<style>
    .stat-card {
        border: none;
        border-radius: 16px;
        padding: 24px;
        color: white;
        position: relative;
        overflow: hidden;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 30px rgba(0,0,0,0.15) !important;
        }

        .stat-card .icon-bg {
            position: absolute;
            right: -10px;
            top: -10px;
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: rgba(255,255,255,0.15);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .stat-card .stat-label {
            font-size: 13px;
            font-weight: 500;
            opacity: 0.85;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }

        .stat-card .stat-number {
            font-size: 38px;
            font-weight: 700;
            line-height: 1;
            margin-bottom: 6px;
        }

        .stat-card .stat-sub {
            font-size: 12px;
            opacity: 0.75;
        }

    .card-blue {
        background: linear-gradient(135deg, #4361ee, #3a86ff);
    }

    .card-green {
        background: linear-gradient(135deg, #2dc653, #1a936f);
    }

    .card-orange {
        background: linear-gradient(135deg, #f77f00, #fcbf49);
    }

    .card-purple {
        background: linear-gradient(135deg, #7209b7, #b5179e);
    }

    .card-red {
        background: linear-gradient(135deg, #e63946, #c1121f);
    }

    .card-teal {
        background: linear-gradient(135deg, #0096c7, #00b4d8);
    }

    .card-dark {
        background: linear-gradient(135deg, #343a40, #495057);
    }

    .section-title {
        font-size: 16px;
        font-weight: 700;
        color: #333;
        margin-bottom: 16px;
        padding-bottom: 8px;
        border-bottom: 2px solid #f0f0f0;
    }

    .chart-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 2px 15px rgba(0,0,0,0.07);
    }

    .pending-badge {
        background: #fff3cd;
        color: #856404;
        border: 1px solid #ffc107;
        border-radius: 8px;
        padding: 4px 10px;
        font-size: 12px;
        font-weight: 600;
    }

    .quick-link {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 16px;
        border-radius: 10px;
        background: #f8f9fa;
        border: 1px solid #e9ecef;
        color: #333;
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        transition: all 0.2s;
        margin-bottom: 10px;
    }

        .quick-link:hover {
            background: #e9ecef;
            color: #000;
            transform: translateX(4px);
        }
</style>

<div class="container-fluid px-4">

    <!-- PAGE HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Admin Dashboard</h2>
            <p class="text-muted mb-0 small">
                Welcome back, @User.Identity?.Name
            </p>
        </div>

        <div class="d-flex align-items-center gap-2">

            @if (Model.PendingTeachersCount > 0)
            {
                <a href="/Teachers/PendingTeachers"
                       class="pending-badge text-decoration-none">
                    ⏳ @Model.PendingTeachersCount Pending Approval
                </a>
            }

            <span class="badge bg-dark px-3 py-2">
                Admin Area
            </span>

        </div>
    </div>

    <!-- SCHOOL STATS -->
    <p class="section-title">📚 School Overview</p>

    <div class="row g-3 mb-4">

        <div class="col-md-3">
            <div class="stat-card card-blue shadow-sm">

                <div class="icon-bg">
                    🎓
                </div>

                <div class="stat-label">Students</div>

                <div class="stat-number">
                    @Model.StudentsCount
                </div>

                <div class="stat-sub">
                    Registered students
                </div>

            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card card-green shadow-sm">

                <div class="icon-bg">
                    👨‍🏫
                </div>

                <div class="stat-label">Teachers</div>

                <div class="stat-number">
                    @Model.TeachersCount
                </div>

                <div class="stat-sub">
                    Approved teachers
                </div>

            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card card-orange shadow-sm">

                <div class="icon-bg">
                    📚
                </div>

                <div class="stat-label">Courses</div>

                <div class="stat-number">
                    @Model.CoursesCount
                </div>

                <div class="stat-sub">
                    Available courses
                </div>

            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card card-purple shadow-sm">

                <div class="icon-bg">
                    📋
                </div>

                <div class="stat-label">Enrollments</div>

                <div class="stat-number">
                    @Model.EnrollmentsCount
                </div>

                <div class="stat-sub">
                    Active enrollments
                </div>

            </div>
        </div>

    </div>

    <!-- USER STATS -->
    <p class="section-title">👥 User Distribution</p>

    <div class="row g-3 mb-4">

        <div class="col-md-4">
            <div class="stat-card card-teal shadow-sm">

                <div class="icon-bg">
                    👤
                </div>

                <div class="stat-label">Users</div>

                <div class="stat-number">
                    @Model.UsersCount
                </div>

                <div class="stat-sub">
                    Registered users
                </div>

            </div>
        </div>

        <div class="col-md-4">
            <div class="stat-card card-dark shadow-sm">

                <div class="icon-bg">
                    🛡️
                </div>

                <div class="stat-label">Admins</div>

                <div class="stat-number">
                    @Model.AdminsCount
                </div>

                <div class="stat-sub">
                    System administrators
                </div>

            </div>
        </div>

        <div class="col-md-4">
            <div class="stat-card card-red shadow-sm">

                <div class="icon-bg">
                    ⏳
                </div>

                <div class="stat-label">Pending Approval</div>

                <div class="stat-number">
                    @Model.PendingTeachersCount
                </div>

                <div class="stat-sub">

                    @if (Model.PendingTeachersCount > 0)
                    {
                        <a href="/Teachers/PendingTeachers"
                               style="color:rgba(255,255,255,0.85);text-decoration:underline;">
                            Review now →
                        </a>
                    }
                    else
                    {
                        <span>No pending teachers</span>
                    }

                </div>

            </div>
        </div>

    </div>

    <!-- QUICK ACTIONS -->
    <div class="row">

        <div class="col-lg-4">

            <div class="chart-card card">

                <div class="card-body p-4">

                    <h5 class="fw-bold mb-3">
                        Quick Actions
                    </h5>

                    <a href="/Teachers/PendingTeachers"
                           class="quick-link">

                        <span style="font-size:18px">
                            ⏳
                        </span>

                        Pending Teacher Approvals

                        @if (Model.PendingTeachersCount > 0)
                        {
                            <span class="badge bg-warning text-dark ms-auto">
                                @Model.PendingTeachersCount
                            </span>
                        }

                    </a>

                    <a href="/Teachers" class="quick-link">
                        👨‍🏫 Manage Teachers
                    </a>

                    <a href="/Students" class="quick-link">
                        🎓 Manage Students
                    </a>

                    <a href="/Courses" class="quick-link">
                        📚 Manage Courses
                    </a>

                    <a href="/Enrollments" class="quick-link">
                        📋 Manage Enrollments
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>