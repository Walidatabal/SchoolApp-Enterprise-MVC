@model List<SchoolApp.ViewModels.Departments.DepartmentListItemVM>

@{
    ViewData["Title"] = "Departments";
}

<div class="container py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Departments</h2>
            <p class="text-muted mb-0">Manage departments in the system.</p>
        </div>

        <a asp-action="Create" class="btn btn-primary">
            + Add Department
        </a>
    </div>

    <!-- Messages -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    <!-- Table -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body">

            <table class="table table-bordered table-striped table-hover align-middle">

                <thead>
                    <tr>
                        <th>Name</th>
                        <th style="width:220px;">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Name</td>

                            <td>
                                <!-- Edit -->
                                <td class="d-flex gap-2">

                                    <a asp-action="Details"
                                           asp-route-id="@item.Id"
                                           class="btn btn-outline-info btn-sm rounded-pill px-3">
                                        Details
                                    </a>

                                    <a asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="btn btn-outline-warning btn-sm rounded-pill px-3">
                                        Edit
                                    </a>

                                    <a asp-action="Delete"
                                           asp-route-id="@item.Id"
                                           class="btn btn-outline-danger btn-sm rounded-pill px-3">
                                        Delete
                                    </a>

                                </td>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>

</div>