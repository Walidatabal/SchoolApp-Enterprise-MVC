@using SchoolApp.Common.Constants
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />

    <!-- Makes the page responsive on mobile -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Page title (dynamic per page) -->
    <title>@ViewData["Title"] - SchoolApp</title>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Custom site styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Auto-generated styles -->
    <link rel="stylesheet" href="~/SchoolApp.styles.css" asp-append-version="true" />
</head>

<body>

    <!-- ================= NAVBAR ================= -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
            <div class="container-fluid">

                <a class="navbar-brand fw-bold" asp-controller="Dashboard" asp-action="Index">
                    SchoolApp
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">

                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                        </li>

                        @if (User.IsInRole(Roles.Admin))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle"
                                       href="#"
                                       role="button"
                                       data-bs-toggle="dropdown">
                                    Admin
                                </a>

                                <ul class="dropdown-menu">
                                    <li>
                                        <a class="dropdown-item"
                                               asp-controller="Users"
                                               asp-action="Index">
                                            Manage Users
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item"
                                               asp-controller="Teachers"
                                               asp-action="PendingTeachers">
                                            Pending Teachers
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item"
                                               asp-controller="Parents"
                                               asp-action="Index">
                                            Parents
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item"
                                               asp-controller="Departments"
                                               asp-action="Index">
                                            Departments
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item"
                                               asp-controller="TeacherCourses"
                                               asp-action="Index">
                                            Teacher Courses
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }

                        @if (User.IsInRole(Roles.Admin) ||
                             User.IsInRole(Roles.Teacher) ||
                             User.IsInRole(Roles.Student))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle"
                                       href="#"
                                       role="button"
                                       data-bs-toggle="dropdown">
                                    School
                                </a>

                                <ul class="dropdown-menu">

                                    @if (User.IsInRole(Roles.Admin) ||
                                         User.IsInRole(Roles.Teacher))
                                    {
                                        <li>
                                            <a class="dropdown-item"
                                                   asp-controller="Students"
                                                   asp-action="Index">
                                                Students
                                            </a>
                                        </li>

                                        <li>
                                            <a class="dropdown-item"
                                                   asp-controller="Teachers"
                                                   asp-action="Index">
                                                Teachers
                                            </a>
                                        </li>

                                        <li>
                                            <a class="dropdown-item"
                                                   asp-controller="Enrollments"
                                                   asp-action="Index">
                                                Enrollments
                                            </a>
                                        </li>
                                    }

                                    @if (User.IsInRole(Roles.Admin) ||
                                         User.IsInRole(Roles.Teacher) ||
                                         User.IsInRole(Roles.Student))
                                    {
                                        <li>
                                            <a class="dropdown-item"
                                                   asp-controller="Courses"
                                                   asp-action="Index">
                                                Courses
                                            </a>
                                        </li>
                                    }

                                </ul>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Profile" asp-action="Index">
                                My Profile
                            </a>
                        </li>

                    </ul>
                    <ul class="navbar-nav ms-auto align-items-lg-center">

                        @if (User.Identity != null &&
                             User.Identity.IsAuthenticated)
                        {
                            <!-- ================= LOGGED-IN USER ================= -->

                            <li class="nav-item me-2">

                                <span class="navbar-text">
                                    Hello @User.Identity.Name
                                </span>

                            </li>

                            <li class="nav-item">

                                <form asp-controller="Account"
                                      asp-action="Logout"
                                      method="post"
                                      class="d-inline">

                                    @Html.AntiForgeryToken()

                                    <button type="submit"
                                            class="btn btn-outline-danger btn-sm">
                                        Logout
                                    </button>

                                </form>

                            </li>
                        }
                        else
                        {
                            <!-- ================= GUEST USER ================= -->

                            <li class="nav-item">

                                <a class="nav-link"
                                       asp-controller="Account"
                                       asp-action="Login">

                                    Login

                                </a>

                            </li>

                            <li class="nav-item">

                                <a class="btn btn-primary btn-sm ms-2"
                                       asp-controller="Account"
                                       asp-action="Register">

                                    Register

                                </a>

                            </li>
                        }

                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- ================= MAIN CONTENT ================= -->
    <div class="container">

        <!-- This is where each page content will be rendered -->
        <main role="main" class="pb-3">
            @RenderBody()
        </main>

    </div>

    <!-- ================= FOOTER ================= -->
    <footer class="border-top footer text-muted">

        <div class="container">
            &copy; 2026 - SchoolApp -

            <a asp-controller="Home" asp-action="Privacy">
                Privacy
            </a>
        </div>

    </footer>

    <!-- ================= SCRIPTS ================= -->
    <!-- jQuery -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <!-- Bootstrap JS -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Custom JS -->
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Optional section for page-specific scripts -->
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>